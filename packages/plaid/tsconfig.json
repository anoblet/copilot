{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "target": "ES2024",
        "lib": [
            "ES2024"
        ],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "allowSyntheticDefaultImports": true,
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "src/**/*"
    ]
}